# Copy this to `.env` and fill in real values for local dev.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cafedb?sslmode=disable

# Backend listen address. (8080 is commonly taken; 8081 is the default here.)
BACKEND_ADDR=:8081

# JWT signing key. Replace with a random 32+ char string in any non-dev env.
JWT_SECRET=dev-jwt-secret-please-change-me

# Customer OTP and JWT lifetimes.
OTP_TTL_SECONDS=300
JWT_TTL_DAYS=30

# SMTP for sending OTP emails. Leave SMTP_HOST blank in dev — the API will
# return `dev_otp` in the response so you can copy-paste without real email.
# Examples:
#   Gmail:  SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=<your-gmail>
#           SMTP_PASS=<gmail APP password, not your account password>
#           SMTP_FROM="Tealogy Cafe <your-gmail>"
#   Resend: SMTP_HOST=smtp.resend.com SMTP_PORT=587  SMTP_USER=resend
#           SMTP_PASS=<resend api key>
#           SMTP_FROM="Tealogy Cafe <onboarding@resend.dev>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
